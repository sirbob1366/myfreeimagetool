---
import Layout from '../layouts/Layout.astro';
import ToolShell from '../components/ToolShell.astro';
---

<Layout title="Crop Image — MyFreeImageTool">
	<ToolShell
		title="Crop Image"
		subtitle="Drag the selection or its corners, snap to a preset ratio, then apply."
	>
		<div class="control-group">
			<h3>Aspect Ratio</h3>
			<div class="row" id="aspect-buttons">
				<button class="btn-ghost active" data-aspect="">Free</button>
				<button class="btn-ghost" data-aspect="1">1:1</button>
				<button class="btn-ghost" data-aspect="1.3333">4:3</button>
				<button class="btn-ghost" data-aspect="1.7778">16:9</button>
				<button class="btn-ghost" data-aspect="0.5625">9:16</button>
			</div>
		</div>
		<div class="control-group">
			<h3>Selection</h3>
			<p id="crop-size" style="margin: 0; color: var(--pewter);"></p>
		</div>
		<button id="apply-btn" class="btn btn-primary">Apply Crop</button>
		<button id="undo-btn" class="btn btn-secondary" disabled>Reset to Original</button>
	</ToolShell>
</Layout>

<script>
	import { initTool } from '../scripts/tool';

	let original: HTMLImageElement | null = null;
	// Current image state (after applied crops), kept on an offscreen canvas.
	const base = document.createElement('canvas');
	const baseCtx = base.getContext('2d')!;

	interface Selection {
		x: number;
		y: number;
		w: number;
		h: number;
	}

	let sel: Selection = { x: 0, y: 0, w: 0, h: 0 };
	let aspect: number | null = null;
	let cropped = false;

	const { canvas, ctx, canvasPoint } = initTool({
		onImage(img) {
			original = img;
			base.width = img.naturalWidth;
			base.height = img.naturalHeight;
			baseCtx.drawImage(img, 0, 0);
			cropped = false;
			undoBtn.disabled = true;
			resetSelection();
			render();
		},
		beforeDownload() {
			// Export the current selection, even if Apply wasn't pressed.
			const w = Math.max(1, Math.round(sel.w));
			const h = Math.max(1, Math.round(sel.h));
			canvas.width = w;
			canvas.height = h;
			ctx.drawImage(base, -Math.round(sel.x), -Math.round(sel.y));
		},
		afterDownload() {
			render();
		},
	});

	function resetSelection() {
		let w = base.width * 0.8;
		let h = base.height * 0.8;
		if (aspect) {
			// Fit the largest aspect-constrained rect within 80% of the image.
			h = w / aspect;
			if (h > base.height * 0.8) {
				h = base.height * 0.8;
				w = h * aspect;
			}
		}
		sel = {
			x: Math.round((base.width - w) / 2),
			y: Math.round((base.height - h) / 2),
			w: Math.round(w),
			h: Math.round(h),
		};
		clampSelection();
	}

	function clampSelection() {
		sel.w = Math.max(10, Math.min(sel.w, base.width));
		sel.h = Math.max(10, Math.min(sel.h, base.height));
		sel.x = Math.max(0, Math.min(sel.x, base.width - sel.w));
		sel.y = Math.max(0, Math.min(sel.y, base.height - sel.h));
	}

	function handleSize() {
		return Math.max(12, base.width / 60);
	}

	function renderClean() {
		canvas.width = base.width;
		canvas.height = base.height;
		ctx.drawImage(base, 0, 0);
	}

	function render() {
		renderClean();

		// Darken the area outside the selection.
		ctx.save();
		ctx.fillStyle = 'rgba(0,0,0,0.5)';
		ctx.beginPath();
		ctx.rect(0, 0, canvas.width, canvas.height);
		ctx.rect(sel.x, sel.y, sel.w, sel.h);
		ctx.fill('evenodd');

		// Selection border.
		ctx.strokeStyle = '#ffffff';
		ctx.lineWidth = Math.max(2, canvas.width / 500);
		ctx.setLineDash([10, 6]);
		ctx.strokeRect(sel.x, sel.y, sel.w, sel.h);
		ctx.setLineDash([]);

		// Corner handles.
		const hs = handleSize();
		ctx.fillStyle = '#ffffff';
		for (const [hx, hy] of corners()) {
			ctx.fillRect(hx - hs / 2, hy - hs / 2, hs, hs);
		}
		ctx.restore();

		updateSizeLabel();
	}

	function corners(): Array<[number, number, string]> {
		return [
			[sel.x, sel.y, 'nw'],
			[sel.x + sel.w, sel.y, 'ne'],
			[sel.x, sel.y + sel.h, 'sw'],
			[sel.x + sel.w, sel.y + sel.h, 'se'],
		];
	}

	const sizeLabel = document.getElementById('crop-size')!;
	function updateSizeLabel() {
		sizeLabel.textContent = `${Math.round(sel.w)} × ${Math.round(sel.h)} px`;
	}

	// ---------- Pointer interaction ----------
	type DragMode = 'move' | 'nw' | 'ne' | 'sw' | 'se' | null;
	let dragMode: DragMode = null;
	let dragStartX = 0;
	let dragStartY = 0;
	let startSel: Selection = { ...sel };

	canvas.addEventListener('pointerdown', (e) => {
		if (!original) return;
		const point = canvasPoint(e);
		const hitRadius = handleSize() * 1.5;

		dragMode = null;
		for (const [hx, hy, name] of corners()) {
			if (
				Math.abs(point.x - hx) <= hitRadius &&
				Math.abs(point.y - hy) <= hitRadius
			) {
				dragMode = name as DragMode;
				break;
			}
		}
		if (
			!dragMode &&
			point.x >= sel.x &&
			point.x <= sel.x + sel.w &&
			point.y >= sel.y &&
			point.y <= sel.y + sel.h
		) {
			dragMode = 'move';
		}
		if (!dragMode) return;

		dragStartX = point.x;
		dragStartY = point.y;
		startSel = { ...sel };
		canvas.setPointerCapture(e.pointerId);
	});

	canvas.addEventListener('pointermove', (e) => {
		if (!dragMode) return;
		const point = canvasPoint(e);
		const dx = point.x - dragStartX;
		const dy = point.y - dragStartY;

		if (dragMode === 'move') {
			sel.x = startSel.x + dx;
			sel.y = startSel.y + dy;
			clampSelection();
			render();
			return;
		}

		// Corner resize: keep the opposite corner anchored.
		let { x, y, w, h } = startSel;
		const right = x + w;
		const bottom = y + h;

		if (dragMode === 'se') {
			w = Math.max(10, startSel.w + dx);
			h = aspect ? w / aspect : Math.max(10, startSel.h + dy);
		} else if (dragMode === 'sw') {
			w = Math.max(10, startSel.w - dx);
			h = aspect ? w / aspect : Math.max(10, startSel.h + dy);
			x = right - w;
		} else if (dragMode === 'ne') {
			w = Math.max(10, startSel.w + dx);
			h = aspect ? w / aspect : Math.max(10, startSel.h - dy);
			y = bottom - h;
		} else if (dragMode === 'nw') {
			w = Math.max(10, startSel.w - dx);
			h = aspect ? w / aspect : Math.max(10, startSel.h - dy);
			x = right - w;
			y = bottom - h;
		}

		// Keep the selection inside the image.
		if (x < 0) {
			w += x;
			if (aspect) h = w / aspect;
			x = 0;
			if (dragMode === 'nw' || dragMode === 'sw') x = right - w;
		}
		if (y < 0) {
			h += y;
			if (aspect) w = h * aspect;
			y = 0;
			if (dragMode === 'nw' || dragMode === 'ne') y = bottom - h;
		}
		if (x + w > base.width) {
			w = base.width - x;
			if (aspect) h = w / aspect;
		}
		if (y + h > base.height) {
			h = base.height - y;
			if (aspect) {
				w = h * aspect;
				if (dragMode === 'nw' || dragMode === 'sw') x = right - w;
			}
		}

		sel = { x, y, w: Math.max(10, w), h: Math.max(10, h) };
		render();
	});

	function endDrag() {
		dragMode = null;
	}
	canvas.addEventListener('pointerup', endDrag);
	canvas.addEventListener('pointercancel', endDrag);

	// ---------- Aspect buttons ----------
	const aspectButtons = document.querySelectorAll<HTMLButtonElement>(
		'#aspect-buttons [data-aspect]',
	);
	aspectButtons.forEach((button) => {
		button.addEventListener('click', () => {
			aspectButtons.forEach((b) => b.classList.remove('active'));
			button.classList.add('active');
			aspect = button.dataset.aspect
				? Number(button.dataset.aspect)
				: null;
			if (aspect && original) {
				// Re-fit the current selection to the new ratio.
				const cx = sel.x + sel.w / 2;
				const cy = sel.y + sel.h / 2;
				let w = sel.w;
				let h = w / aspect;
				if (h > base.height) {
					h = base.height;
					w = h * aspect;
				}
				if (w > base.width) {
					w = base.width;
					h = w / aspect;
				}
				sel = { x: cx - w / 2, y: cy - h / 2, w, h };
				clampSelection();
				render();
			}
		});
	});

	// ---------- Apply / reset ----------
	const undoBtn = document.getElementById('undo-btn') as HTMLButtonElement;

	document.getElementById('apply-btn')!.addEventListener('click', () => {
		if (!original) return;
		const region = {
			x: Math.round(sel.x),
			y: Math.round(sel.y),
			w: Math.round(sel.w),
			h: Math.round(sel.h),
		};
		const next = document.createElement('canvas');
		next.width = region.w;
		next.height = region.h;
		next
			.getContext('2d')!
			.drawImage(base, -region.x, -region.y);
		base.width = next.width;
		base.height = next.height;
		baseCtx.drawImage(next, 0, 0);
		cropped = true;
		undoBtn.disabled = false;
		resetSelection();
		render();
	});

	undoBtn.addEventListener('click', () => {
		if (!original || !cropped) return;
		base.width = original.naturalWidth;
		base.height = original.naturalHeight;
		baseCtx.drawImage(original, 0, 0);
		cropped = false;
		undoBtn.disabled = true;
		resetSelection();
		render();
	});
</script>

<style is:global>
	#apply-btn,
	#undo-btn {
		width: 100%;
	}
	#canvas {
		cursor: crosshair;
	}
</style>
