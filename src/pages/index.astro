---
import Layout from '../layouts/Layout.astro';

const tools = [
	{
		href: '/adjust',
		title: 'Adjust Colors',
		desc: 'Fine-tune brightness, contrast, saturation, exposure, temperature, and vignette with live sliders.',
	},
	{
		href: '/filters',
		title: 'Photo Filters',
		desc: 'One-click preset filters — vintage, noir, vivid, warm, cool, and more — with adjustable intensity.',
	},
	{
		href: '/text',
		title: 'Add Text',
		desc: 'Place text on your photo. Choose fonts, sizes, colors, and outlines, then drag it anywhere.',
	},
	{
		href: '/shapes',
		title: 'Add Shapes',
		desc: 'Overlay rectangles, ellipses, lines, and arrows. Scale, recolor, and position them freely.',
	},
	{
		href: '/crop',
		title: 'Crop Image',
		desc: 'Crop to any region with draggable handles, or snap to presets like square, 4:3, and 16:9.',
	},
	{
		href: '/resize',
		title: 'Resize & Rotate',
		desc: 'Scale to exact dimensions, keep aspect ratio, rotate in 90° steps, and flip horizontally or vertically.',
	},
	{
		href: '/remove-background',
		title: 'Remove Background',
		desc: 'Click a color to make it transparent. Adjust tolerance and export as a transparent PNG.',
	},
];
---

<Layout>
	<section class="hero">
		<h1>Free image tools</h1>
		<p>
			Edit photos right in your browser. No uploads, no accounts, no
			watermarks — your files never leave your device.
		</p>
		<div class="cta-row">
			<a href="/adjust" class="btn btn-primary">Start Editing</a>
			<a href="#tools" class="btn btn-secondary">Browse Tools</a>
		</div>
	</section>

	<section id="tools" class="tool-grid">
		{
			tools.map((tool) => (
				<a href={tool.href} class="tool-card">
					<h2>{tool.title}</h2>
					<p>{tool.desc}</p>
					<span class="open-link">Open</span>
				</a>
			))
		}
	</section>
</Layout>
