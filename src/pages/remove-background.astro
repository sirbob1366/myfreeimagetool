---
import Layout from '../layouts/Layout.astro';
import ToolShell from '../components/ToolShell.astro';
---

<Layout title="Remove Background — Free Image Tools">
	<ToolShell
		title="Remove Background"
		subtitle="Click any color in your image to make it transparent. No AI — pure color matching."
		checkered
	>
		<div class="control-group">
			<h3>How it works</h3>
			<p style="margin: 0; color: var(--pewter);">
				Click a color on the image to erase it. Raise the tolerance to
				catch similar shades. Use Contiguous to only erase the connected
				area you clicked.
			</p>
		</div>
		<div class="control-group">
			<div class="field">
				<label>Tolerance <output>25</output></label>
				<input type="range" id="tolerance" min="1" max="100" value="25" />
			</div>
			<label class="checkbox">
				<input type="checkbox" id="contiguous" checked /> Contiguous (connected area only)
			</label>
			<div class="field">
				<label>Soften Edges <output>1</output></label>
				<input type="range" id="feather" min="0" max="3" value="1" />
			</div>
		</div>
		<button id="undo-btn" class="btn btn-secondary" disabled>Undo</button>
		<button id="reset-btn" class="btn btn-secondary" disabled>Reset</button>
	</ToolShell>
</Layout>

<script>
	import { initTool, bindRange } from '../scripts/tool';

	let image: HTMLImageElement | null = null;
	let tolerance = 25;
	let contiguous = true;
	let feather = 1;
	// Removal only ever changes the alpha channel, so undo snapshots store
	// just alpha — 4× smaller than full ImageData copies.
	const undoStack: Uint8ClampedArray[] = [];
	const maxUndo = 20;

	// The canvas stores premultiplied alpha, which destroys the RGB of fully
	// transparent pixels. All edits happen on this in-memory buffer, which is
	// the single source of truth; the canvas is display-only.
	let working: ImageData | null = null;

	const undoBtn = document.getElementById('undo-btn') as HTMLButtonElement;
	const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;

	const { canvas, ctx, canvasPoint } = initTool({
		onImage(img) {
			image = img;
			undoStack.length = 0;
			ctx.clearRect(0, 0, canvas.width, canvas.height);
			ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
			working = ctx.getImageData(0, 0, canvas.width, canvas.height);
			updateButtons();
		},
		downloadName: 'transparent.png',
	});

	bindRange('tolerance', (value) => {
		tolerance = value;
	});
	bindRange('feather', (value) => {
		feather = value;
	});
	(document.getElementById('contiguous') as HTMLInputElement).addEventListener(
		'change',
		(e) => {
			contiguous = (e.target as HTMLInputElement).checked;
		},
	);

	function updateButtons() {
		undoBtn.disabled = undoStack.length === 0;
		resetBtn.disabled = undoStack.length === 0;
	}

	canvas.addEventListener('pointerdown', (e) => {
		if (!image || !working) return;
		const point = canvasPoint(e);
		const x = Math.floor(point.x);
		const y = Math.floor(point.y);
		if (x < 0 || y < 0 || x >= canvas.width || y >= canvas.height) return;

		const d = working.data;

		// Nothing to remove if the clicked pixel is already transparent.
		if (d[(y * canvas.width + x) * 4 + 3] === 0) return;

		// Save the alpha channel for undo.
		const pixelCount = canvas.width * canvas.height;
		const alphaSnapshot = new Uint8ClampedArray(pixelCount);
		for (let p = 0; p < pixelCount; p++) {
			alphaSnapshot[p] = d[p * 4 + 3];
		}
		undoStack.push(alphaSnapshot);
		if (undoStack.length > maxUndo) undoStack.shift();

		if (contiguous) {
			floodRemove(working, x, y);
		} else {
			globalRemove(working, x, y);
		}
		if (feather > 0) softenEdges(working);
		ctx.putImageData(working, 0, 0);
		updateButtons();
	});

	function threshold() {
		const t = (tolerance / 100) * 255;
		return t * t * 3;
	}

	function globalRemove(imageData: ImageData, sx: number, sy: number) {
		const d = imageData.data;
		const idx = (sy * imageData.width + sx) * 4;
		const tr = d[idx];
		const tg = d[idx + 1];
		const tb = d[idx + 2];
		const limit = threshold();
		for (let i = 0; i < d.length; i += 4) {
			if (d[i + 3] === 0) continue;
			const dr = d[i] - tr;
			const dg = d[i + 1] - tg;
			const db = d[i + 2] - tb;
			if (dr * dr + dg * dg + db * db <= limit) {
				d[i + 3] = 0;
			}
		}
	}

	function floodRemove(imageData: ImageData, sx: number, sy: number) {
		const { width, height } = imageData;
		const d = imageData.data;
		const startIdx = (sy * width + sx) * 4;
		if (d[startIdx + 3] === 0) return;
		const tr = d[startIdx];
		const tg = d[startIdx + 1];
		const tb = d[startIdx + 2];
		const limit = threshold();

		const visited = new Uint8Array(width * height);
		const stack = [sy * width + sx];
		visited[sy * width + sx] = 1;

		while (stack.length > 0) {
			const pos = stack.pop()!;
			const i = pos * 4;
			if (d[i + 3] === 0) continue;
			const dr = d[i] - tr;
			const dg = d[i + 1] - tg;
			const db = d[i + 2] - tb;
			if (dr * dr + dg * dg + db * db > limit) continue;

			d[i + 3] = 0;

			const px = pos % width;
			const py = (pos / width) | 0;
			if (px > 0 && !visited[pos - 1]) {
				visited[pos - 1] = 1;
				stack.push(pos - 1);
			}
			if (px < width - 1 && !visited[pos + 1]) {
				visited[pos + 1] = 1;
				stack.push(pos + 1);
			}
			if (py > 0 && !visited[pos - width]) {
				visited[pos - width] = 1;
				stack.push(pos - width);
			}
			if (py < height - 1 && !visited[pos + width]) {
				visited[pos + width] = 1;
				stack.push(pos + width);
			}
		}
	}

	/**
	 * Soften the boundary between opaque and transparent pixels by reducing
	 * the alpha of opaque pixels that border fully transparent ones.
	 */
	function softenEdges(imageData: ImageData) {
		const { width, height } = imageData;
		const d = imageData.data;
		const passes = feather;
		for (let pass = 0; pass < passes; pass++) {
			const alpha = new Uint8ClampedArray(width * height);
			for (let p = 0; p < width * height; p++) {
				alpha[p] = d[p * 4 + 3];
			}
			for (let y = 0; y < height; y++) {
				for (let x = 0; x < width; x++) {
					const p = y * width + x;
					if (alpha[p] === 0) continue;
					let transparentNeighbors = 0;
					if (x > 0 && alpha[p - 1] === 0) transparentNeighbors++;
					if (x < width - 1 && alpha[p + 1] === 0) transparentNeighbors++;
					if (y > 0 && alpha[p - width] === 0) transparentNeighbors++;
					if (y < height - 1 && alpha[p + width] === 0)
						transparentNeighbors++;
					if (transparentNeighbors > 0) {
						d[p * 4 + 3] = Math.round(
							alpha[p] * (1 - transparentNeighbors * 0.2),
						);
					}
				}
			}
		}
	}

	undoBtn.addEventListener('click', () => {
		const previousAlpha = undoStack.pop();
		if (previousAlpha && working) {
			const d = working.data;
			for (let p = 0; p < previousAlpha.length; p++) {
				d[p * 4 + 3] = previousAlpha[p];
			}
			ctx.putImageData(working, 0, 0);
		}
		updateButtons();
	});

	resetBtn.addEventListener('click', () => {
		if (!image) return;
		undoStack.length = 0;
		ctx.clearRect(0, 0, canvas.width, canvas.height);
		ctx.drawImage(image, 0, 0, canvas.width, canvas.height);
		working = ctx.getImageData(0, 0, canvas.width, canvas.height);
		updateButtons();
	});
</script>

<style is:global>
	#undo-btn,
	#reset-btn {
		width: 100%;
	}
	#canvas {
		cursor: crosshair;
	}
</style>
